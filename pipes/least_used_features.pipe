NODE least_used_node
SQL >
    %
    SELECT 
        feature_name,
        selector,
        count() as clicks,
        max(url) as page,
        max(timestamp) as last_clicked
    FROM events
    WHERE project_id = {{ String(project_id, 'required') }}
        AND timestamp >= now() - INTERVAL 30 DAY
    GROUP BY feature_name, selector
    HAVING clicks < {{ Int32(threshold, 10) }}
    ORDER BY clicks ASC, last_clicked DESC
    LIMIT {{ Int32(limit, 50) }}
