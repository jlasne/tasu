NODE top_features_node
SQL >
    %
    SELECT 
        feature_name,
        selector,
        count() as clicks,
        uniq(user_id) as unique_users,
        max(url) as page
    FROM events
    WHERE project_id = {{ String(project_id, 'required') }}
        AND timestamp >= now() - INTERVAL {{ Int32(days, 7) }} DAY
    GROUP BY feature_name, selector
    ORDER BY clicks DESC
    LIMIT {{ Int32(limit, 100) }}
